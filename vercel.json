{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "nodeVersion": "20.x"
      }
    }
  ],
  "build": {
    "env": {
      "NEXT_TELEPERFORMANCE_DISABLED": "1",
      "NODE_ENV": "production"
    },
    "command": "npm install --platform=linux --arch=x64 && npm run build"
  }
}
