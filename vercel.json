{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "nodeVersion": "20.x"
      }
    }
  ],
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "NODE_ENV": "production",
      "NPM_CONFIG_PLATFORM": "linux",
      "NPM_CONFIG_ARCH": "x64"
    },
    "command": "chmod +x ./scripts/vercel-build.sh && ./scripts/vercel-build.sh"
  },
  "installCommand": "chmod +x ./scripts/vercel-build.sh && ./scripts/vercel-build.sh"
}
