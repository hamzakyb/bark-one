# Disable SWC binary download and force Linux x64
SWC_BINARY_DOWNLOAD=false
SWC_BINARY_PATH=@next/swc-linux-x64-gnu

# Platform settings
platform=linux
target_arch=x64

# Force npm to use the correct platform
npm_config_platform=linux
npm_config_arch=x64
npm_config_target_arch=x64

# Node.js settings
NODE_OPTIONS=--no-experimental-fetch

# Installation settings
legacy-peer-deps=true
strict-peer-deps=false
prefer-offline=true
frozen-lockfile=false

# Cache settings
cache-min=999999999
prefer-offline=true
prefer-online=false

# Ensure correct SWC binary is used
@next:registry=https://registry.npmjs.org/
